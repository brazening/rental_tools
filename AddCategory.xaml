<Window x:Class="Rental.AddCategory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rental"
        mc:Ignorable="d"
        Title="Ввод категории" 
        Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        MinHeight="400" MinWidth="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма ввода данных -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="15" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Поле: name (название категории) -->
                <TextBlock Grid.Column="0" 
                           Grid.Row="0" 
                           Text="Название категории:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"
                           Margin="3"/>
                <TextBox Grid.Column="1" 
                         Grid.Row="0" 
                         x:Name="txtName" 
                         Height="28" 
                         FontSize="12"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3" 
                         MaxLength="100"
                         PreviewTextInput="txtName_PreviewTextInput"/>

                <!-- Кнопки -->
                <StackPanel Grid.Column="1" 
                            Grid.Row="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="3">
                    <Button x:Name="btnAdd" 
                            Content="➕ Добавить" 
                            Width="110" 
                            Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" 
                            FontSize="13" 
                            Cursor="Hand"
                            Click="btnAdd_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnEdit" 
                            Content="✏️ Редактировать" 
                            Width="128" 
                            Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" 
                            FontSize="13" 
                            Cursor="Hand"
                            Click="btnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" 
                            Content="🗑️ Очистить" 
                            Width="110" 
                            Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" 
                            FontSize="13" 
                            Cursor="Hand"
                            Click="btnClear_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
          x:Name="dgCategories"
          AutoGenerateColumns="False" 
          Background="White"
          BorderBrush="#555555"
          BorderThickness="1"
          AlternatingRowBackground="#F5F5F5"
          RowHeight="35" 
          FontSize="11"
          Foreground="#333333"
          CanUserResizeColumns="True"
          SelectionChanged="dgCategories_SelectionChanged"
          IsReadOnly="True"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">

            <DataGrid.Resources>
                <!-- Стиль для ячейки -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для строки -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для заголовков строк -->
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Колонка: name (название категории) -->
                <DataGridTextColumn Header="Название категории" 
                            Binding="{Binding Name}" 
                            Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25" 
                   Background="#4D4D4D" 
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>