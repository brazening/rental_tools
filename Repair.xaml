<Window x:Class="Rental.Repair"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ремонт" 
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма для ввода данных -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 1 -->
                <!-- Инструмент -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="🔧 Инструмент:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                          x:Name="cmbTool"
                          Height="28" FontSize="12" Margin="3"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          IsEditable="False"
                          SelectionChanged="cmbTool_SelectionChanged"/>

                <!-- Сотрудник -->
                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="👤 Сотрудник:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="0" Grid.Column="3" 
                          x:Name="cmbEmployee"
                          Height="28" FontSize="12" Margin="3"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          IsEditable="False"/>

                <!-- Статус ремонта (только для просмотра) -->
                <TextBlock Grid.Row="0" Grid.Column="4" 
                           Text="📊 Статус:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="0" Grid.Column="5" 
                         x:Name="txtStatus"
                         Height="28" FontSize="12" Margin="3"
                         IsReadOnly="True"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"/>

                <!-- Строка 2 -->
                <!-- Описание проблемы -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="📝 Описание проблемы:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Top" Margin="3,8,3,3"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                         x:Name="txtIssueDescription"
                         Height="60" FontSize="12" Margin="3"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         MaxLength="1000"/>

                <!-- Строка 3 -->
                <!-- Стоимость ремонта -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="💰 Стоимость ремонта:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         x:Name="txtCost"
                         Height="28" FontSize="12" Margin="3"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         PreviewTextInput="TextBox_PreviewTextInput_Numeric"/>

                <!-- Дата начала -->
                <TextBlock Grid.Row="2" Grid.Column="2" 
                           Text="📅 Дата начала:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <DatePicker Grid.Row="2" Grid.Column="3" 
                            x:Name="dpStartDate"
                            Height="28" FontSize="12" Margin="3"
                            Background="#F8F8F8"
                            BorderBrush="#AAAAAA"
                            SelectedDateFormat="Short"/>

                <!-- Дата окончания -->
                <TextBlock Grid.Row="2" Grid.Column="4" 
                           Text="✅ Дата окончания:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <DatePicker Grid.Row="2" Grid.Column="5" 
                            x:Name="dpEndDate"
                            Height="28" FontSize="12" Margin="3"
                            Background="#F8F8F8"
                            BorderBrush="#AAAAAA"
                            SelectedDateFormat="Short"/>

                <!-- Строка 4 - Кнопки управления статусом -->
                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" 
                        Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="5"
                        Padding="10" Margin="3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Управление статусом:" 
                                   FontWeight="Bold" FontSize="13"
                                   Foreground="#333333"
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button x:Name="btnSetInProgress" 
                                Content="🟡 В процессе"
                                Width="120" Height="32" Margin="5"
                                Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                                FontWeight="Bold" FontSize="12"
                                Cursor="Hand"
                                Click="btnSetInProgress_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnSetWaiting" 
                                Content="⏳ Ожидает запчастей"
                                Width="150" Height="32" Margin="5"
                                Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                                FontWeight="Bold" FontSize="12"
                                Cursor="Hand"
                                Click="btnSetWaiting_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnSetCompleted" 
                                Content="✅ Завершить"
                                Width="120" Height="32" Margin="5"
                                Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                                FontWeight="Bold" FontSize="12"
                                Cursor="Hand"
                                Click="btnSetCompleted_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnSetCancelled" 
                                Content="❌ Отменить"
                                Width="110" Height="32" Margin="5"
                                Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                                FontWeight="Bold" FontSize="12"
                                Cursor="Hand"
                                Click="btnSetCancelled_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Строка 5 - Основные кнопки -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" 
                            Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnAdd" 
                            Content="➕ Добавить"
                            Width="110" Height="32" Margin="5"
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            Click="btnAdd_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnEdit" 
                            Content="✏️ Редактировать"
                            Width="128" Height="32" Margin="5"
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="btnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" 
                            Content="🗑️ Очистить"
                            Width="110" Height="32" Margin="5"
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            Click="btnClear_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
          x:Name="dgRepairs"
          AutoGenerateColumns="False"
          Background="White"
          BorderBrush="#555555"
          BorderThickness="1"
          AlternatingRowBackground="#F5F5F5"
          RowHeight="40"
          FontSize="11"
          Foreground="#333333"
          CanUserResizeColumns="True"
          IsReadOnly="True"
          SelectionChanged="dgRepairs_SelectionChanged"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Инструмент (инв. номер)" 
                            Binding="{Binding ToolInventoryNumber}"
                            Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Сотрудник" 
                            Binding="{Binding EmployeeFIO}"
                            Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Описание проблемы" 
                            Binding="{Binding IssueDescription}"
                            Width="250">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Статус" 
                            Binding="{Binding Status}"
                            Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Стоимость" 
                            Binding="{Binding Cost, StringFormat=N2}"
                            Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Дата начала" 
                            Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}"
                            Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Дата окончания" 
                            Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}"
                            Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25"
                   Background="#4D4D4D"
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="statusText" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>