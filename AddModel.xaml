<Window x:Class="Rental.AddModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rental"
        mc:Ignorable="d"
        Title="Ввод моделей" 
        Height="700" Width="1085"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма ввода данных -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Строка 1: Название и Категория -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Название модели:" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         x:Name="txtName" 
                         Height="28" FontSize="12" 
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3" MaxLength="150"/>

                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="Категория:" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="0" Grid.Column="3" 
                          x:Name="cmbCategory" 
                          Height="28" FontSize="12" 
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          Margin="3" 
                          DisplayMemberPath="Name" 
                          SelectedValuePath="Id"/>

                <!-- Строка 2: Цена аренды и Коэф. просрочки -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Цена аренды (₽/день):" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         x:Name="txtRentalPrice" 
                         Height="28" FontSize="12" 
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3" MaxLength="10"
                         PreviewTextInput="Number_PreviewTextInput"/>

                <TextBlock Grid.Row="1" Grid.Column="2" 
                           Text="Коэф. просрочки:" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="1" Grid.Column="3" 
                         x:Name="txtOverdueCoefficient" 
                         Height="28" FontSize="12" 
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3" MaxLength="6"
                         PreviewTextInput="Decimal_PreviewTextInput"
                         LostFocus="TxtOverdueCoefficient_LostFocus"/>

                <!-- Строка 3: Срок службы и Общее количество -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Срок службы (мес.):" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         x:Name="txtServiceLifeMonths" 
                         Height="28" FontSize="12" 
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3" MaxLength="4"
                         PreviewTextInput="Number_PreviewTextInput"
                         ToolTip="Срок службы в месяцах (целое число)"/>

                <TextBlock Grid.Row="2" Grid.Column="2" 
                           Text="Общее количество:" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>

                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Margin="3">
                    <TextBox x:Name="txtTotalQuantity" 
                             Width="100"
                             Height="28" FontSize="12" 
                             Background="#F8F8F8"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             IsReadOnly="True"/>
                    <Button x:Name="btnShowStockDetails"
                            Width="28" Height="28"
                            Margin="5,0,0,0"
                            Background="#4D4D4D"
                            Foreground="White"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="14"
                            Cursor="Hand"
                            ToolTip="Показать распределение по складам"
                            Click="BtnShowStockDetails_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6D6D6D"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#3D3D3D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="📊" FontSize="14" TextAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Строка 4: Кнопки действий -->
                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="6" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Left"
                            Margin="0,5,0,5">
                    <Button x:Name="btnAdd" 
                            Content="➕ Добавить" 
                            Width="110" Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13" 
                            Cursor="Hand"
                            Click="BtnAdd_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnEdit" 
                            Content="✏️ Редактировать" 
                            Width="126" Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13" 
                            Cursor="Hand"
                            Click="BtnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" 
                            Content="🗑️ Очистить" 
                            Width="110" Height="32" 
                            Margin="5" 
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13" 
                            Cursor="Hand"
                            Click="BtnClear_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Строка 5: Описание -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Описание:" 
                           FontWeight="Bold" FontSize="13" 
                           Foreground="#333333"
                           VerticalAlignment="Top" Margin="3"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         x:Name="txtDescription" 
                         Height="50" FontSize="12" 
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3,3,3,3" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         MaxLength="1000"/>
            </Grid>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
          x:Name="dgToolModels"
          AutoGenerateColumns="False"
          Background="White"
          BorderBrush="#555555"
          BorderThickness="1"
          AlternatingRowBackground="#F5F5F5"
          RowHeight="35"
          FontSize="11"
          Foreground="#333333"
          CanUserResizeColumns="True"
          SelectionChanged="DgToolModels_SelectionChanged"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">

            <DataGrid.Resources>
                <!-- Стиль для ячейки -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для строки -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для заголовков строк -->
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название модели" 
                            Binding="{Binding Name}" 
                            Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Категория" 
                            Binding="{Binding CategoryName}" 
                            Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Описание" 
                            Binding="{Binding Description}" 
                            Width="230">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Цена аренды (₽/день)" 
                            Binding="{Binding RentalPrice, StringFormat=N2}" 
                            Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Коэф. просрочки" 
                            Binding="{Binding OverdueCoefficient, StringFormat=F2}" 
                            Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Срок службы (мес.)" 
                            Binding="{Binding ServiceLifeMonths}" 
                            Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Общее кол-во" 
                            Binding="{Binding TotalQuantity}" 
                            Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25"
                   Background="#4D4D4D"
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>