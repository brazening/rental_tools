<Window x:Class="Rental.WriteOff"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Списание" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма для ввода данных -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 1 -->
                <!-- Инструмент -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="🔧 Инструмент:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                          x:Name="cmbTool"
                          Height="28" FontSize="12" Margin="3"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          IsEditable="False"
                          SelectionChanged="cmbTool_SelectionChanged"/>

                <!-- Сотрудник -->
                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="👤 Сотрудник:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="0" Grid.Column="3" 
                          x:Name="cmbEmployee"
                          Height="28" FontSize="12" Margin="3"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          IsEditable="False"/>

                <!-- Дата списания -->
                <TextBlock Grid.Row="0" Grid.Column="4" 
                           Text="📅 Дата списания:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <DatePicker Grid.Row="0" Grid.Column="5" 
                            x:Name="dpWriteOffDate"
                            Height="28" FontSize="12" Margin="3"
                            Background="#F8F8F8"
                            BorderBrush="#AAAAAA"
                            SelectedDateFormat="Short"
                            SelectedDateChanged="dpWriteOffDate_SelectedDateChanged"/>

                <!-- Строка 2 -->
                <!-- Причина списания (выпадающий список) -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="📝 Причина списания:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                          x:Name="cmbReason"
                          Height="28" FontSize="12" Margin="3"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True">
                    <ComboBox.ItemsSource>
                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:String>Полный физический износ</sys:String>
                            <sys:String>Повреждение (несовместимое с ремонтом)</sys:String>
                            <sys:String>Устаревание</sys:String>
                            <sys:String>Утеря/кража</sys:String>
                            <sys:String>Ошибка инвентаризации</sys:String>
                        </x:Array>
                    </ComboBox.ItemsSource>
                </ComboBox>

                <!-- Строка 3 -->
                <!-- Остаточная стоимость -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="💰 Остаточная стоимость:" 
                           FontWeight="Bold" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center" Margin="3"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         x:Name="txtResidualValue"
                         Height="28" FontSize="12" Margin="3"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         PreviewTextInput="TextBox_PreviewTextInput_Numeric"/>

                <!-- Информация о расчёте -->
                <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="4" 
                           x:Name="txtCalcInfo"
                           FontSize="11" FontStyle="Italic"
                           Foreground="#555555"
                           VerticalAlignment="Center" Margin="3"
                           Text=""/>

                <!-- Строка 4 - Кнопки -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" 
                            Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnAdd" 
                            Content="➕ Добавить"
                            Width="130" Height="32" Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            Click="btnAdd_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnEdit" 
                            Content="✏️ Редактировать"
                            Width="130" Height="32" Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="btnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" 
                            Content="🗑️ Очистить"
                            Width="130" Height="32" Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            Click="btnClear_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
                  x:Name="dgWriteOffs"
                  AutoGenerateColumns="False"
                  Background="White"
                  BorderBrush="#555555"
                  BorderThickness="1"
                  AlternatingRowBackground="#F5F5F5"
                  RowHeight="35"
                  FontSize="11"
                  Foreground="#333333"
                  CanUserResizeColumns="True"
                  IsReadOnly="True"
                  SelectionChanged="dgWriteOffs_SelectionChanged"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#DDDDDD"
                  RowHeaderWidth="0">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Инструмент (инв. номер)" 
                                    Binding="{Binding ToolInventoryNumber}"
                                    Width="150*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Сотрудник" 
                                    Binding="{Binding EmployeeFIO}"
                                    Width="200*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Причина списания" 
                                    Binding="{Binding Reason}"
                                    Width="250*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Остаточная стоимость" 
                                    Binding="{Binding ResidualValue, StringFormat=N2}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Дата списания" 
                                    Binding="{Binding WriteOffDate, StringFormat=dd.MM.yyyy}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25"
                   Background="#4D4D4D"
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="statusText" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>