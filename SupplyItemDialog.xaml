<Window x:Class="Rental.SupplyItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор модели инструмента" Height="600" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D2D">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Выберите модель инструмента и укажите количество и цену закупки" 
                   FontWeight="Bold" FontSize="14" 
                   Foreground="#F0F0F0" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <DataGrid x:Name="dgToolModels" Grid.Row="1" AutoGenerateColumns="False" 
                  Background="White" 
                  BorderBrush="#555555" 
                  BorderThickness="1"
                  AlternatingRowBackground="#F5F5F5" 
                  RowHeight="35" 
                  FontSize="12"
                  Foreground="#333333"
                  SelectionChanged="DgToolModels_SelectionChanged">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="300">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Цена аренды (руб/день)" Binding="{Binding RentalPrice, StringFormat='N2'}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="В наличии (шт.)" Binding="{Binding AvailableQuantity}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Выбрана модель:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtSelectedModel" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5" 
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="В наличии:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtAvailableQuantity" Grid.Row="1" Grid.Column="1" 
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Склад:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <ComboBox x:Name="cboStock" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA"
                         DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Количество:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtQuantity" Grid.Row="3" Grid.Column="1" 
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"
                         TextChanged="TxtQuantity_TextChanged"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="Цена закупки:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtPurchasePrice" Grid.Row="3" Grid.Column="3" 
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"
                         TextChanged="TxtPurchasePrice_TextChanged"/>

                <TextBlock Grid.Row="3" Grid.Column="4" Text="Итого:" FontWeight="Bold" FontSize="13" 
                           Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtTotalPrice" Grid.Row="3" Grid.Column="5" 
                         Height="28" FontSize="12" Margin="3" 
                         Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"
                         IsReadOnly="True"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="💾 Добавить позицию" Width="172" Height="32" 
                    Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                    FontWeight="Bold" FontSize="13" Cursor="Hand" Click="BtnSave_Click" Margin="5" IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8B8B8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="btnCancel" Content="❌ Отмена" Width="100" Height="32" 
                    Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                    FontWeight="Bold" FontSize="13" Cursor="Hand" Click="BtnCancel_Click" Margin="5">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8B8B8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>