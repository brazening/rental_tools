<Window x:Class="Rental.RentalViewForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр договора аренды" 
        Height="800" Width="1200"
        Background="#2D2D2D"
        FontFamily="Times New Roman"
        WindowStartupLocation="CenterOwner"
        MinHeight="600" MinWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Основная информация о договоре -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📄 Основная информация" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="№ договора:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtId" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" FontWeight="Bold"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Статус:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtStatus" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" FontWeight="Bold"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Кол-во дней:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="0" Grid.Column="5" x:Name="txtDaysCount" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtClient" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Сотрудник:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" x:Name="txtEmployee" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Период аренды:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Row="1" Grid.Column="5" x:Name="txtPeriod" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Доставка -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🚚 Доставка" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Город:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Column="1" x:Name="txtCity" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>

                    <TextBlock Grid.Column="2" Text="Статус доставки:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Column="3" x:Name="txtDeliveryStatus" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>

                    <TextBlock Grid.Column="4" Text="Стоимость доставки:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Column="5" x:Name="txtDeliveryCost" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" TextAlignment="Right"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Адрес доставки:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Column="1" x:Name="txtDeliveryAddress" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3" TextWrapping="Wrap"/>

                    <TextBlock Grid.Column="2" Text="Дата доставки:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                    <TextBlock Grid.Column="3" x:Name="txtDeliveryDate" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Арендованные инструменты -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🔧 Арендованные инструменты" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>

                <!-- Информация о просрочке -->
                <Border Grid.Row="1" Background="#F8F8F8" CornerRadius="4" Padding="10" Margin="0,0,0,10" BorderBrush="#AAAAAA" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="⚠️ Информация:" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="3"/>
                        <TextBlock x:Name="txtOverdueInfo" Grid.Column="1" FontSize="12" Foreground="#333333" Margin="3"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="dgTools" Grid.Row="2" AutoGenerateColumns="False" 
          Background="White" BorderBrush="#555555" BorderThickness="1"
          AlternatingRowBackground="#F5F5F5" RowHeight="35" 
          FontSize="12" Foreground="#333333" CanUserResizeColumns="True"
          VerticalScrollBarVisibility="Auto"
          ScrollViewer.CanContentScroll="True"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRowHeader">
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Инструмент" Binding="{Binding ToolInventoryNumber}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Цена за день" Binding="{Binding PricePerDay, StringFormat=N2}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Дата возврата" Binding="{Binding ReturnDate, StringFormat=dd.MM.yyyy}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridCheckBoxColumn Header="Поврежден" Binding="{Binding IsDamaged}" Width="80">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Штрафы и итоговая сумма -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Grid.Row="0" Text="💰 Штрафы" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>

                <!-- Сводка по штрафам -->
                <Border Grid.Row="1" Background="#F8F8F8" CornerRadius="4" Padding="10" Margin="0,0,0,10" BorderBrush="#AAAAAA" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Штраф за просрочку -->
                        <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="⚠️ Просрочка" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                                <TextBlock Grid.Row="1" x:Name="txtOverdueFineAmount" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,5,0,0"/>
                                <TextBlock Grid.Row="2" x:Name="txtOverdueFineDesc" FontSize="10" Foreground="#333333" Margin="0,3,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Штраф за поломку -->
                        <Border Grid.Column="1" Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="4" Padding="8" Margin="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="🔨 Поломка" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                                <TextBlock Grid.Row="1" x:Name="txtDamageFineAmount" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,5,0,0"/>
                                <TextBlock Grid.Row="2" x:Name="txtDamageFineDesc" FontSize="10" Foreground="#333333" Margin="0,3,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Таблица штрафов -->
                <DataGrid Grid.Row="2" x:Name="dgFines" AutoGenerateColumns="False" 
          Background="White" BorderBrush="#555555" BorderThickness="1"
          AlternatingRowBackground="#F5F5F5" RowHeight="30" 
          FontSize="11" Foreground="#333333" CanUserResizeColumns="True"
          MaxHeight="150" MinHeight="50" 
          VerticalScrollBarVisibility="Auto"
          Margin="0,0,0,10"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRowHeader">
                            <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Тип штрафа" Binding="{Binding FineType}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Дата начисления" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Инструмент" Binding="{Binding ToolName}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Разделитель -->
                <Separator Grid.Row="3" Background="#AAAAAA" Height="2" Margin="0,5"/>

                <!-- Итоговая сумма -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🏆 Итоговая сумма:" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="5" Foreground="#333333"/>
                    <TextBox Grid.Column="1" x:Name="txtTotalPrice" Height="45" FontSize="18" Margin="5" 
                             IsEnabled="False" Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1" FontWeight="Bold" TextAlignment="Right" Foreground="#333333"/>
                    <TextBlock Grid.Column="2" Text="₽" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="5" Foreground="#333333"/>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="3" x:Name="btnClose" Content="✖️ Закрыть" Width="130" Height="40" Margin="10,5" 
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="13" Cursor="Hand"
                            HorizontalAlignment="Right" Click="btnClose_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>