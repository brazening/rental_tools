<Window x:Class="Rental.MassAddWithDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Массовое добавление инструментов" 
        Height="820" Width="650" 
        WindowStartupLocation="CenterOwner"
        Background="#2D2D2D"
        FontFamily="Times New Roman"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#4D4D4D" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,15">
            <TextBlock Text="📦 Массовое добавление инструментов" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="#F0F0F0" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Выбор модели -->
        <Border Grid.Row="1" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Модель инструмента:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" 
                          x:Name="cmbModel" 
                          Height="30" 
                          FontSize="12"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          Margin="5,0"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>
                <Button Grid.Column="2" 
                        x:Name="btnRefreshModels" 
                        Content="🔄" 
                        Width="30" 
                        Height="30" 
                        Margin="5,0"
                        Background="#E8E8E8"
                        Foreground="#333333"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        FontWeight="Bold" 
                        FontSize="14"
                        Cursor="Hand"
                        Click="BtnRefreshModels_Click" 
                        ToolTip="Обновить список моделей">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#B8B8B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Выбор склада -->
        <Border Grid.Row="2" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Склад:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" 
                          x:Name="cmbStock" 
                          Height="30" 
                          FontSize="12"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          Margin="5,0"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>
            </Grid>
        </Border>

        <!-- Параметры инструмента -->
        <Border Grid.Row="3" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="⚙️ Параметры инструмента" 
                           FontWeight="Bold" 
                           FontSize="14"
                           Foreground="#333333"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Статус:" 
                               FontWeight="Bold" 
                               FontSize="12"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              x:Name="cmbStatus" 
                              Height="28" 
                              FontSize="12"
                              Background="#F8F8F8"
                              BorderBrush="#AAAAAA">
                        <ComboBoxItem Content="доступен" IsSelected="True"/>
                        <ComboBoxItem Content="в аренде"/>
                        <ComboBoxItem Content="на ремонте"/>
                        <ComboBoxItem Content="списан"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Состояние:" 
                               FontWeight="Bold" 
                               FontSize="12"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" 
                              x:Name="cmbCondition" 
                              Height="28" 
                              FontSize="12"
                              Background="#F8F8F8"
                              BorderBrush="#AAAAAA">
                        <ComboBoxItem Content="отличное" IsSelected="True"/>
                        <ComboBoxItem Content="хорошее"/>
                        <ComboBoxItem Content="удовлетворительное"/>
                        <ComboBoxItem Content="плохое"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Цена покупки:" 
                               FontWeight="Bold" 
                               FontSize="12"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             x:Name="txtPurchasePrice" 
                             Height="28" 
                             FontSize="12"
                             Background="#F8F8F8"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             PreviewTextInput="NumberValidationTextBox"
                             ToolTip="Необязательное поле"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Дата покупки:" 
                               FontWeight="Bold" 
                               FontSize="12"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>
                    <DatePicker Grid.Column="1" 
                                x:Name="dpPurchaseDate" 
                                Height="28" 
                                FontSize="12"
                                Background="#F8F8F8"
                                BorderBrush="#AAAAAA"
                                SelectedDate="{x:Static sys:DateTime.Today}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Количество -->
        <Border Grid.Row="4" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Количество:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" 
                         x:Name="txtQuantity" 
                         Height="30" 
                         FontSize="12"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="5,0"
                         PreviewTextInput="NumberOnlyValidation"/>
                <TextBlock Grid.Column="2" 
                           Text="(max 100)" 
                           FontSize="11" 
                           Foreground="#333333" 
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Предпросмотр инвентарных номеров -->
        <Border Grid.Row="5" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🏷️ Предпросмотр инвентарных номеров" 
                           FontWeight="Bold" 
                           FontSize="13"
                           Foreground="#333333"
                           Margin="0,0,0,8"/>
                <ListBox x:Name="lstPreview" 
                         Height="120" 
                         FontSize="11"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         Foreground="#333333"/>
                <Button x:Name="btnGeneratePreview" 
                        Content="🔄 Сгенерировать предпросмотр" 
                        Height="30" 
                        Margin="0,8,0,0"
                        Background="#E8E8E8"
                        Foreground="#333333"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnGeneratePreview_Click">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#B8B8B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Статус -->
        <Border Grid.Row="6" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="5" 
                Padding="8" 
                Margin="0,0,0,10">
            <TextBlock x:Name="txtStatus" 
                       Text="Готов к добавлению" 
                       FontSize="11" 
                       Foreground="#333333"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10">
            <Button x:Name="btnAdd" 
                    Content="✅ Добавить" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#E8E8E8"
                    Foreground="#333333"
                    BorderBrush="#888888"
                    BorderThickness="1"
                    FontWeight="Bold" 
                    FontSize="13"
                    Cursor="Hand"
                    Click="BtnAdd_Click">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8B8B8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="btnCancel" 
                    Content="❌ Отмена" 
                    Width="100" 
                    Height="35" 
                    Margin="5"
                    Background="#E8E8E8"
                    Foreground="#333333"
                    BorderBrush="#888888"
                    BorderThickness="1"
                    FontWeight="Bold" 
                    FontSize="13"
                    Cursor="Hand"
                    Click="BtnCancel_Click">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8B8B8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>