<Window x:Class="Rental.AddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rental"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Ввод клиентов" 
        Height="700" Width="1190"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        ResizeMode="CanResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма ввода -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="15"
                Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Строка 1: Тип -->
                    <Label Grid.Row="0" Grid.Column="0" 
                           Content="Тип клиента:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" 
                              x:Name="cmbType"
                              Height="28" 
                              FontSize="12"
                              FontFamily="Times New Roman"
                              Background="#F8F8F8"
                              BorderBrush="#AAAAAA"
                              Margin="3"
                              IsEditable="False">
                        <ComboBoxItem Content="Физическое лицо"/>
                        <ComboBoxItem Content="Юридическое лицо"/>
                        <ComboBoxItem Content="ИП"/>
                    </ComboBox>

                    <!-- Строка 2: ФИО / Название -->
                    <Label Grid.Row="1" Grid.Column="0" 
                           Content="ФИО / Название:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             x:Name="txtName"
                             Height="28" 
                             FontSize="12"
                             FontFamily="Times New Roman"
                             Background="#F8F8F8"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             Margin="3"
                             MaxLength="150"
                             ToolTip="Только буквы, пробелы и дефисы"
                             PreviewTextInput="TextBoxLettersOnly_PreviewTextInput"/>

                    <!-- Строка 3: Телефон -->
                    <Label Grid.Row="0" Grid.Column="2" 
                           Content="Телефон:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <xctk:MaskedTextBox Grid.Row="0" Grid.Column="3" 
                                        x:Name="txtPhone"
                                        Mask="+7 (999) 999-99-99"
                                        PromptChar="_"
                                        Height="28" 
                                        FontSize="12"
                                        FontFamily="Times New Roman"
                                        Background="#F8F8F8"
                                        BorderBrush="#AAAAAA"
                                        BorderThickness="1"
                                        Margin="3"
                                        ToolTip="Формат: +7 (999) 999-99-99"/>

                    <!-- Строка 4: Email -->
                    <Label Grid.Row="1" Grid.Column="2" 
                           Content="Почта:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="3" 
                             x:Name="txtEmail"
                             Height="28" 
                             FontSize="12"
                             FontFamily="Times New Roman"
                             Background="#F8F8F8"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             Margin="3"
                             MaxLength="100"
                             ToolTip="example@mail.com"/>

                    <!-- Строка 5: Серия паспорта -->
                    <Label Grid.Row="2" Grid.Column="0" 
                           Content="Серия паспорта:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <xctk:MaskedTextBox Grid.Row="2" Grid.Column="1" 
                                        x:Name="txtPassportSeries"
                                        Mask="9999"
                                        PromptChar="_"
                                        Height="28" 
                                        FontSize="12"
                                        FontFamily="Times New Roman"
                                        Background="#F8F8F8"
                                        BorderBrush="#AAAAAA"
                                        BorderThickness="1"
                                        Margin="3"
                                        ToolTip="4 цифры"/>

                    <!-- Строка 6: Номер паспорта -->
                    <Label Grid.Row="2" Grid.Column="2" 
                           Content="Номер паспорта:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <xctk:MaskedTextBox Grid.Row="2" Grid.Column="3" 
                                        x:Name="txtPassportNumber"
                                        Mask="999999"
                                        PromptChar="_"
                                        Height="28" 
                                        FontSize="12"
                                        FontFamily="Times New Roman"
                                        Background="#F8F8F8"
                                        BorderBrush="#AAAAAA"
                                        BorderThickness="1"
                                        Margin="3"
                                        ToolTip="6 цифр"/>

                    <!-- Строка 7: Кем выдан (без обработчика PreviewTextInput) -->
                    <Label Grid.Row="3" Grid.Column="0" 
                           Content="Кем выдан:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                             x:Name="txtIssuedBy"
                             Height="28" 
                             FontSize="12"
                             FontFamily="Times New Roman"
                             Background="#F8F8F8"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             Margin="3"
                             MaxLength="255"
                             Width="400"
                             HorizontalAlignment="Left"
                             ToolTip="Кем выдан паспорт (только буквы, пробелы и знаки препинания)"/>

                    <!-- Строка 8: Код подразделения -->
                    <Label Grid.Row="4" Grid.Column="0" 
                           Content="Код подразделения:" 
                           FontWeight="Bold" 
                           FontSize="13"
                           FontFamily="Times New Roman"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                    <xctk:MaskedTextBox Grid.Row="4" Grid.Column="1" 
                                        x:Name="txtDepartmentCode"
                                        Mask="999-999"
                                        PromptChar="_"
                                        Height="28" 
                                        FontSize="12"
                                        FontFamily="Times New Roman"
                                        Background="#F8F8F8"
                                        BorderBrush="#AAAAAA"
                                        BorderThickness="1"
                                        Margin="3"
                                        ToolTip="6 цифр (формат: 000-000)"/>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="3">
                        <Button x:Name="btnAdd" 
                                Content="➕ Добавить"
                                Width="130" Height="32"
                                Margin="5"
                                Background="#E8E8E8"
                                Foreground="#333333"
                                BorderBrush="#888888"
                                BorderThickness="1"
                                FontWeight="Bold"
                                FontSize="13"
                                FontFamily="Times New Roman"
                                Cursor="Hand"
                                Click="BtnAdd_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnEdit" 
                                Content="✏️ Редактировать"
                                Width="130" Height="32"
                                Margin="5"
                                Background="#E8E8E8"
                                Foreground="#333333"
                                BorderBrush="#888888"
                                BorderThickness="1"
                                FontWeight="Bold"
                                FontSize="13"
                                FontFamily="Times New Roman"
                                Cursor="Hand"
                                Click="BtnEdit_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnClear" 
                                Content="🗑️ Очистить"
                                Width="130" Height="32"
                                Margin="5"
                                Background="#E8E8E8"
                                Foreground="#333333"
                                BorderBrush="#888888"
                                BorderThickness="1"
                                FontWeight="Bold"
                                FontSize="13"
                                FontFamily="Times New Roman"
                                Cursor="Hand"
                                Click="BtnClear_Click">
                            <Button.Resources>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#B8B8B8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
          x:Name="dgClients"
          AutoGenerateColumns="False"
          Background="White"
          BorderBrush="#555555"
          BorderThickness="1"
          AlternatingRowBackground="#F5F5F5"
          RowHeight="35"
          FontSize="11"
          FontFamily="Times New Roman"
          Foreground="#333333"
          CanUserResizeColumns="True"
          SelectionChanged="DgClients_SelectionChanged"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">

            <DataGrid.Resources>
                <!-- Стиль для ячейки при выделении -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для строки при выделении -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для заголовков строк -->
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип клиента" 
                            Binding="{Binding Type}"
                            Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="ФИО / Название" 
                            Binding="{Binding Name}"
                            Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Телефон" 
                            Binding="{Binding Phone}"
                            Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Почта" 
                            Binding="{Binding Email}"
                            Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Серия паспорта" 
                            Binding="{Binding PassportSeries}"
                            Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Номер паспорта" 
                            Binding="{Binding PassportNumber}"
                            Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Кем выдан" 
                            Binding="{Binding IssuedBy}"
                            Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Код подразделения" 
                            Binding="{Binding DepartmentCode}"
                            Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25"
                   Background="#4D4D4D"
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           FontFamily="Times New Roman"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>