<Window x:Class="Rental.AddSupplier"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод поставщиков" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Форма для ввода данных -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                BorderBrush="#555555" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" MaxLength="200" 
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="ИНН:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtINN" Grid.Row="0" Grid.Column="3" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" 
                         MaxLength="12" PreviewTextInput="txtNumericOnly_PreviewTextInput"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="КПП:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtKPP" Grid.Row="0" Grid.Column="5" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" 
                         MaxLength="9" PreviewTextInput="txtNumericOnly_PreviewTextInput"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <!-- Строка 2 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="ОГРН:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtOGRN" Grid.Row="1" Grid.Column="1" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" 
                         MaxLength="15" PreviewTextInput="txtNumericOnly_PreviewTextInput"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Юр. адрес:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtLegalAddress" Grid.Row="1" Grid.Column="3" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" MaxLength="500" Grid.ColumnSpan="3"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <!-- Строка 3 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtPhone" Grid.Row="2" Grid.Column="1" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" 
                         MaxLength="11" PreviewTextInput="txtNumericOnly_PreviewTextInput"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Почта:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtEmail" Grid.Row="2" Grid.Column="3" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" MaxLength="100" Grid.ColumnSpan="3"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <!-- Строка 4 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Контактное лицо:" VerticalAlignment="Center" Margin="3" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                <TextBox x:Name="txtContactPerson" Grid.Row="3" Grid.Column="1" Margin="3" Background="#F8F8F8" Height="28" FontSize="12" MaxLength="150" 
                         PreviewTextInput="txtLetterOnly_PreviewTextInput"
                         BorderBrush="#AAAAAA" BorderThickness="1"/>

                <!-- Кнопки -->
                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="3">
                    <Button x:Name="btnAdd" Content="➕ Добавить" Width="120" Height="32" Margin="5" 
                            Click="btnAdd_Click" FontWeight="Bold" FontSize="13" Cursor="Hand"
                            BorderBrush="#888888" BorderThickness="1">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnEdit" Content="✏️ Редактировать" Width="120" Height="32" Margin="5" 
                            Click="btnEdit_Click" FontWeight="Bold" FontSize="13" Cursor="Hand"
                            BorderBrush="#888888" BorderThickness="1">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnClear" Content="🗑️ Очистить" Width="120" Height="32" Margin="5" 
                            Click="btnClear_Click" FontWeight="Bold" FontSize="13" Cursor="Hand"
                            BorderBrush="#888888" BorderThickness="1">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="dgSuppliers" Grid.Row="1" AutoGenerateColumns="False" SelectionChanged="dgSuppliers_SelectionChanged"
                  Background="White" BorderBrush="#555555" BorderThickness="1" RowHeaderWidth="0" FontSize="11"
                  AlternatingRowBackground="#F5F5F5" RowHeight="42" CanUserResizeColumns="True"
                  Foreground="#333333" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DDDDDD">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="100" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="КПП" Binding="{Binding Kpp}" Width="90" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ОГРН" Binding="{Binding Ogrn}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Юр. адрес" Binding="{Binding LegalAddress}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="100" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Почта" Binding="{Binding Email}" Width="130" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactPerson}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Margin" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Background="#4D4D4D" Margin="0,10,0,0" Height="25">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Foreground="#F0F0F0" FontWeight="Bold" FontSize="12">Готово</TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>