<Window x:Class="Rental.Movement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перемещение" 
        Height="700" Width="910" 
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Часть 1: Форма для перемещения -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 0 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Инструмент:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <ComboBox x:Name="cmbTool" Grid.Row="0" Grid.Column="1" Height="28" FontSize="12" Margin="3" Background="#F8F8F8" BorderBrush="#AAAAAA" SelectionChanged="CmbTool_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding InventoryNumber}" Width="100" FontWeight="Bold"/>
                                <TextBlock Text=" - " />
                                <TextBlock Text="{Binding ModelName}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Текущий склад:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <TextBox x:Name="txtCurrentStock" Grid.Row="0" Grid.Column="3" Height="28" FontSize="12" Margin="3" IsReadOnly="True" Background="#F8F8F8" BorderBrush="#AAAAAA" BorderThickness="1"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Дата:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <DatePicker x:Name="dpMovementDate" Grid.Row="0" Grid.Column="5" Height="28" FontSize="12" Background="#F8F8F8" BorderBrush="#AAAAAA" Margin="3"/>

                <!-- Строка 1 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Со склада:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <ComboBox x:Name="cmbFromStock" Grid.Row="1" Grid.Column="1" Height="28" FontSize="12" Margin="3" Background="#F8F8F8" BorderBrush="#AAAAAA" DisplayMemberPath="name" SelectedValuePath="id"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="На склад:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <ComboBox x:Name="cmbToStock" Grid.Row="1" Grid.Column="3" Height="28" FontSize="12" Margin="3" Background="#F8F8F8" BorderBrush="#AAAAAA" DisplayMemberPath="name" SelectedValuePath="id"/>

                <!-- Строка 2 - Сотрудник -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Сотрудник:" FontWeight="Bold" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Margin="3"/>
                <ComboBox x:Name="cmbEmployee" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5" Height="28" FontSize="12" Margin="3" Background="#F8F8F8" BorderBrush="#AAAAAA" SelectedValuePath="id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding fio}" FontWeight="Bold"/>
                                <TextBlock Text=" (" />
                                <TextBlock Text="{Binding role}" />
                                <TextBlock Text=")" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="3,15,3,3">
                    <Button x:Name="btnPost" Content="✅ Переместить" Width="130" Height="32" Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnPost_Click" Margin="3">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" Content="🗑️ Очистить" Width="100" Height="32" Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnClear_Click" Margin="3">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Часть 2: DataGrid перемещений -->
        <DataGrid x:Name="dgMovements" Grid.Row="1" AutoGenerateColumns="False" Background="White" 
          BorderBrush="#555555" BorderThickness="1" AlternatingRowBackground="#F5F5F5" 
          RowHeight="40" FontSize="13" Foreground="#333333"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">
            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding MovementDate, StringFormat='dd.MM.yyyy'}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Модель" Binding="{Binding ModelName}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Со склада" Binding="{Binding FromStockName}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="На склад" Binding="{Binding ToStockName}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeFio}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Часть 3: StatusBar -->
        <StatusBar Grid.Row="2" Height="25" Background="#4D4D4D" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готово" FontWeight="Bold" FontSize="11" Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>