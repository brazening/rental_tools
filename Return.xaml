<Window x:Class="Rental.Return"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Возврат инструментов" 
        Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D"
        FontFamily="Times New Roman"
        MinHeight="650" MinWidth="1100">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор договора -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Договор:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="cmbRental" Grid.Column="1" Height="30" FontSize="13" Margin="5" 
                          Background="#F8F8F8" BorderBrush="#AAAAAA"
                          DisplayMemberPath="Text" SelectedValuePath="Id"
                          SelectionChanged="CmbRental_SelectionChanged"/>
                <Button x:Name="btnRefresh" Grid.Column="2" Content="🔄" Width="40" Height="30" Margin="5" 
                        Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                        FontWeight="Bold" FontSize="14" Cursor="Hand" Click="BtnRefresh_Click">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#B8B8B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Информация о договоре -->
        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Клиент:" FontWeight="Bold" FontSize="13" Foreground="#333333" Margin="5"/>
                    <TextBlock x:Name="txtClient" Grid.Column="1" Margin="5" Foreground="#333333" FontWeight="Bold"/>

                    <TextBlock Grid.Column="2" Text="Телефон:" FontWeight="Bold" FontSize="13" Foreground="#333333" Margin="5"/>
                    <TextBlock x:Name="txtPhone" Grid.Column="3" Margin="5" Foreground="#333333"/>

                    <TextBlock Grid.Column="4" Text="Дата начала:" FontWeight="Bold" FontSize="13" Foreground="#333333" Margin="5"/>
                    <TextBlock x:Name="txtStartDate" Grid.Column="5" Margin="5" Foreground="#333333"/>

                    <TextBlock Grid.Column="6" Text="Дата окончания:" FontWeight="Bold" FontSize="13" Foreground="#333333" Margin="5"/>
                    <TextBlock x:Name="txtEndDate" Grid.Column="7" Margin="5" FontWeight="Bold" Foreground="#333333"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Список инструментов -->
        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🔧 Инструменты в договоре" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333333"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <DataGrid x:Name="dgTools" AutoGenerateColumns="False" 
          Background="White" BorderBrush="#555555" BorderThickness="1"
          AlternatingRowBackground="#F5F5F5" RowHeight="80" 
          FontSize="12" Foreground="#333333" CanUserResizeColumns="True"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          MinWidth="1200"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRowHeader">
                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="Margin" Value="5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Модель" Binding="{Binding ModelName}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="Margin" Value="5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Цена/день" Binding="{Binding PricePerDay, StringFormat=N2}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="Margin" Value="5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Статус" Width="380">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="✅ Возвращен" 
                        Width="100" Height="35"
                        Background="#E8E8E8"
                        Foreground="#333333"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        FontWeight="Bold"
                        FontSize="11"
                        Cursor="Hand"
                        Click="BtnReturned_Click"
                        Tag="{Binding}"
                        Margin="2"
                        IsEnabled="{Binding CanReturn}">
                                                <Button.Resources>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#D0D0D0"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#B8B8B8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                                <Setter Property="Foreground" Value="#999999"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Content="⚠️ Поломан" 
                        Width="90" Height="35"
                        Background="#E8E8E8"
                        Foreground="#333333"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        FontWeight="Bold"
                        FontSize="11"
                        Cursor="Hand"
                        Click="BtnBroken_Click"
                        Tag="{Binding}"
                        Margin="2"
                        IsEnabled="{Binding CanReturn}">
                                                <Button.Resources>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#D0D0D0"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#B8B8B8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                                <Setter Property="Foreground" Value="#999999"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Content="❌ Утерян" 
                        Width="80" Height="35"
                        Background="#E8E8E8"
                        Foreground="#333333"
                        BorderBrush="#888888"
                        BorderThickness="1"
                        FontWeight="Bold"
                        FontSize="11"
                        Cursor="Hand"
                        Click="BtnLost_Click"
                        Tag="{Binding}"
                        Margin="2"
                        IsEnabled="{Binding CanReturn}">
                                                <Button.Resources>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#D0D0D0"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#B8B8B8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                                <Setter Property="Foreground" Value="#999999"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Штраф, ₽" Binding="{Binding Fine, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Итого и кнопка -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📅 Просрочка:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtOverdueDays" FontSize="13" FontWeight="Bold" Foreground="#333333" Margin="10,0" VerticalAlignment="Center"/>

                        <TextBlock Text="💰 Штраф за просрочку:" FontWeight="Bold" FontSize="13" Foreground="#333333" VerticalAlignment="Center" Margin="30,0,0,0"/>
                        <TextBlock x:Name="txtOverdueFine" FontSize="14" FontWeight="Bold" Foreground="#333333" Margin="10,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Separator Grid.Row="1" Background="#AAAAAA" Height="2" Margin="0,5"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🏆 ИТОГО ШТРАФОВ:" FontWeight="Bold" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalFine" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="₽" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="btnReturn" Grid.Column="1" Content="✅ ЗАВЕРШИТЬ ВОЗВРАТ" Width="220" Height="45" Margin="10,0" 
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="13" Cursor="Hand"
                            IsEnabled="False" Click="BtnReturn_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="btnCalcAll" Grid.Column="2" Content="📊 Пересчитать" Width="130" Height="35" Margin="10,0" 
                            Background="#E8E8E8" Foreground="#333333" BorderBrush="#888888" BorderThickness="1"
                            FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnCalcAll_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>