<Window x:Class="Rental.AddEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Rental"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Ввод сотрудников" 
        Height="700" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя часть - форма ввода -->
        <Border Grid.Row="0" 
                Background="#FFFFFF" 
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6" 
                Padding="15"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Строка 0: ФИО -->
                <Label Grid.Row="0" Grid.Column="0" 
                       Content="ФИО:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         x:Name="txtFIO"
                         Height="28" 
                         FontSize="12"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3"
                         MaxLength="150"
                         ToolTip="Введите полное ФИО сотрудника"
                         PreviewTextInput="FIO_PreviewTextInput"/>

                <!-- Строка 0: Должность -->
                <Label Grid.Row="0" Grid.Column="2" 
                       Content="Должность:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="3" 
                          x:Name="cmbRole"
                          Height="28" 
                          FontSize="12"
                          Background="#F8F8F8"
                          BorderBrush="#AAAAAA"
                          Margin="3"
                          IsEditable="True"
                          IsTextSearchEnabled="True">
                    <ComboBoxItem Content="Администратор"/>
                    <ComboBoxItem Content="Менеджер"/>
                    <ComboBoxItem Content="Кладовщик"/>
                </ComboBox>

                <!-- Строка 0: Телефон с маской -->
                <Label Grid.Row="0" Grid.Column="4" 
                       Content="Телефон:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <xctk:MaskedTextBox Grid.Row="0" Grid.Column="5" 
                                    x:Name="txtPhone"
                                    Mask="+7 (999) 999-99-99"
                                    PromptChar="_"
                                    Height="28" 
                                    FontSize="12"
                                    FontFamily="Times New Roman"
                                    Background="#F8F8F8"
                                    BorderBrush="#AAAAAA"
                                    BorderThickness="1"
                                    Margin="3"
                                    ToolTip="Формат: +7 (999) 999-99-99"/>

                <!-- Строка 1: Серия паспорта с маской -->
                <Label Grid.Row="1" Grid.Column="0" 
                       Content="Серия паспорта:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <xctk:MaskedTextBox Grid.Row="1" Grid.Column="1" 
                                    x:Name="txtPassportSeries"
                                    Mask="9999"
                                    PromptChar="_"
                                    Height="28" 
                                    FontSize="12"
                                    Background="#F8F8F8"
                                    BorderBrush="#AAAAAA"
                                    BorderThickness="1"
                                    Margin="3"
                                    ToolTip="4 цифры"/>

                <!-- Строка 1: Номер паспорта с маской -->
                <Label Grid.Row="1" Grid.Column="2" 
                       Content="Номер паспорта:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <xctk:MaskedTextBox Grid.Row="1" Grid.Column="3" 
                                    x:Name="txtPassportNumber"
                                    Mask="999999"
                                    PromptChar="_"
                                    Height="28" 
                                    FontSize="12"
                                    Background="#F8F8F8"
                                    BorderBrush="#AAAAAA"
                                    BorderThickness="1"
                                    Margin="3"
                                    ToolTip="6 цифр"/>

                <!-- Строка 1: Код подразделения с маской -->
                <Label Grid.Row="1" Grid.Column="4" 
                       Content="Код подразделения:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <xctk:MaskedTextBox Grid.Row="1" Grid.Column="5" 
                                    x:Name="txtDepartmentCode"
                                    Mask="999-999"
                                    PromptChar="_"
                                    Height="28" 
                                    FontSize="12"
                                    Background="#F8F8F8"
                                    BorderBrush="#AAAAAA"
                                    BorderThickness="1"
                                    Margin="3"
                                    ToolTip="6 цифр (формат: 000-000)"/>

                <!-- Строка 2: Кем выдан -->
                <Label Grid.Row="2" Grid.Column="0" 
                       Content="Кем выдан:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="1" 
                         x:Name="txtIssuedBy"
                         Height="28" 
                         FontSize="12"
                         Background="#F8F8F8"
                         BorderBrush="#AAAAAA"
                         BorderThickness="1"
                         Margin="3"
                         MaxLength="255"
                         ToolTip="Наименование органа, выдавшего паспорт"/>

                <!-- Строка 2: Дата рождения -->
                <Label Grid.Row="2" Grid.Column="2" 
                       Content="Дата рождения:" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333333"
                       VerticalAlignment="Center"/>
                <DatePicker Grid.Row="2" Grid.Column="3" 
                            x:Name="dpDateBirth"
                            Height="28" 
                            FontSize="12"
                            Background="#F8F8F8"
                            BorderBrush="#AAAAAA"
                            Margin="3,10,113,10"
                            SelectedDate="1990-01-01"/>

                <!-- Строка 2: Кнопки -->
                <StackPanel Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="172,0,0,0" Width="417">
                    <Button x:Name="btnAdd" 
                            Content="➕ Добавить" 
                            Width="130" Height="32"
                            Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold"
                            FontSize="13"
                            Cursor="Hand"
                            Click="btnAdd_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnEdit" 
                            Content="✏️ Редактировать" 
                            Width="130" Height="32"
                            Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold"
                            FontSize="13"
                            Cursor="Hand"
                            Click="btnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnClear" 
                            Content="🗑️ Очистить" 
                            Width="130" Height="32"
                            Margin="5"
                            Background="#E8E8E8"
                            Foreground="#333333"
                            BorderBrush="#888888"
                            BorderThickness="1"
                            FontWeight="Bold"
                            FontSize="13"
                            Cursor="Hand"
                            Click="btnClear_Click">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#B8B8B8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Центральная часть - DataGrid -->
        <DataGrid Grid.Row="1" 
          x:Name="dgEmployees"
          AutoGenerateColumns="False"
          Background="White"
          BorderBrush="#555555"
          BorderThickness="1"
          AlternatingRowBackground="#F5F5F5"
          RowHeight="35"
          FontSize="11"
          Foreground="#333333"
          CanUserResizeColumns="True"
          SelectionChanged="dgEmployees_SelectionChanged"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#DDDDDD"
          RowHeaderWidth="0">

            <DataGrid.Resources>
                <!-- Стиль для ячейки -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для строки -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Стиль для заголовков строк -->
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#DDDDDD"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                            Binding="{Binding Id}" 
                            Width="50"
                            Visibility="Collapsed"/>

                <DataGridTextColumn Header="ФИО" 
                            Binding="{Binding Fio}" 
                            Width="250"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Должность" 
                            Binding="{Binding Role}" 
                            Width="120"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Телефон" 
                            Binding="{Binding Phone}" 
                            Width="130"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Серия паспорта" 
                            Binding="{Binding PassportSeries}" 
                            Width="100"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Номер паспорта" 
                            Binding="{Binding PassportNumber}" 
                            Width="100"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Код подразделения" 
                            Binding="{Binding DepartmentCode}" 
                            Width="110"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Кем выдан" 
                            Binding="{Binding IssuedBy}" 
                            Width="200"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Дата рождения" 
                            Binding="{Binding DateBirth, StringFormat='dd.MM.yyyy'}" 
                            Width="100"
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#333333"/>
                            <Setter Property="Margin" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя часть - StatusBar -->
        <StatusBar Grid.Row="2" 
                   Height="25"
                   Background="#4D4D4D"
                   Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" 
                           Text="Готово" 
                           FontWeight="Bold" 
                           FontSize="12"
                           Foreground="#F0F0F0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>